# Environment
ENVIRONMENT=dev
LOG_LEVEL=DEBUG

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/hireloop
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Redis
REDIS_URL=redis://localhost:6379/0

# AWS
AWS_REGION=us-east-1
AWS_S3_BUCKET=hireloop-dev-assets
# Optional: LocalStack or MinIO (leave unset for real AWS)
# AWS_ENDPOINT_URL=http://localhost:4566
# AWS_ACCESS_KEY_ID=test
# AWS_SECRET_ACCESS_KEY=test

# Agent (Phase 2a)
AGENT_MESSAGE_RATE_LIMIT_PER_MINUTE=10
AGENT_MAX_HISTORY_MESSAGES=20
LLM_CLASSIFIER_TIMEOUT_S=3.0
LLM_EVALUATION_TIMEOUT_S=60.0
LLM_CV_OPTIMIZE_TIMEOUT_S=90.0

# Cognito
COGNITO_USER_POOL_ID=us-east-1_xxxxxxxxx
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
COGNITO_REGION=us-east-1
COGNITO_JWKS_URL=https://cognito-idp.us-east-1.amazonaws.com/us-east-1_xxxxxxxxx/.well-known/jwks.json

# AI Providers
ANTHROPIC_API_KEY=sk-ant-placeholder
GOOGLE_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6
GEMINI_MODEL=gemini-2.0-flash-exp
ENABLE_PROMPT_CACHING=true

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175

# Sentry
SENTRY_DSN=
SENTRY_ENVIRONMENT=dev

# Billing — Stripe (Phase 2b)
APP_URL=http://localhost:5173
DISABLE_PAYWALL=false
TRIAL_PERIOD_DAYS=3
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_ANNUAL=

# ==========================================
# Phase 2c — Inngest
# ==========================================
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
INNGEST_DEV=1
FEATURE_SCAN_SCHEDULING=false

# ==========================================
# Phase 2c — Scanning limits
# ==========================================
SCAN_MAX_LISTINGS_PER_RUN=500
SCAN_BOARD_RATE_LIMIT_REQS_PER_SEC=1
SCAN_L1_CONCURRENCY=5
BATCH_L2_CONCURRENCY=10
BATCH_L1_RELEVANCE_THRESHOLD=0.5
